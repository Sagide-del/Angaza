# ── Server ──────────────────────────────────────────────
PORT=3000
ADMIN_KEY=choose-a-long-random-string

# ── File storage ────────────────────────────────────────
# Checked in this order: Supabase Storage -> Vercel Blob -> local disk.
# Only fill in ONE of these two blocks (or neither, for local dev).

# Option A: Supabase Storage — create a project at supabase.com, add a
# Storage bucket (default name "content", or set SUPABASE_BUCKET), make it
# public, then use the *service_role* key here (Settings -> API). Never use
# the anon/publishable key for this — service_role stays server-side only.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_KEY=…
# SUPABASE_BUCKET=content

# Option B: Vercel Blob — added AUTOMATICALLY when you create a Blob store
# in the Vercel dashboard. You do NOT set this by hand.
# BLOB_READ_WRITE_TOKEN=…

# ── Catalogue/orders storage (Vercel) ───────────────────
# Added AUTOMATICALLY when you connect a KV/Redis database (e.g. via the
# Vercel Marketplace -> Upstash) in the Vercel dashboard. You do NOT set
# these by hand.
# KV_REST_API_URL=…
# KV_REST_API_TOKEN=…
# Leave all of the above blank locally to use the dev fallback (JSON + local disk).

# ── M-Pesa Daraja (Safaricom) ───────────────────────────
MPESA_ENV=sandbox                 # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=                  # your Paybill or Till number
MPESA_PASSKEY=
MPESA_CALLBACK_URL=               # https://<your-domain>/api/mpesa/callback

# ── WhatsApp delivery ───────────────────────────────────
# provider: meta | twilio | (blank = log to console for manual sending)
# Your WhatsApp number (254...) to receive new-order alerts in manual mode:
OWNER_PHONE=

WHATSAPP_PROVIDER=
META_PHONE_ID=
META_TOKEN=
TWILIO_SID=
TWILIO_AUTH=
TWILIO_FROM=whatsapp:+14155238886
