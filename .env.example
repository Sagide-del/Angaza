# ── Server ──────────────────────────────────────────────
PORT=3000
ADMIN_KEY=choose-a-long-random-string

# ── Storage (Vercel) ────────────────────────────────────
# These are added AUTOMATICALLY when you create Blob + KV stores
# in the Vercel dashboard. You do NOT set them by hand.
# BLOB_READ_WRITE_TOKEN=…        (from Vercel Blob)
# KV_REST_API_URL=…              (from Vercel KV)
# KV_REST_API_TOKEN=…            (from Vercel KV)
# Leave all blank locally to use the dev fallback (JSON + local disk).

# ── M-Pesa Daraja (Safaricom) ───────────────────────────
MPESA_ENV=sandbox                 # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=                  # your Paybill or Till number
MPESA_PASSKEY=
MPESA_CALLBACK_URL=               # https://<your-domain>/api/mpesa/callback

# ── WhatsApp delivery ───────────────────────────────────
# provider: meta | twilio | (blank = log to console for manual sending)
# Your WhatsApp number (254...) to receive new-order alerts in manual mode:
OWNER_PHONE=

WHATSAPP_PROVIDER=
META_PHONE_ID=
META_TOKEN=
TWILIO_SID=
TWILIO_AUTH=
TWILIO_FROM=whatsapp:+14155238886
